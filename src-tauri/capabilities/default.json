{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-internal-toggle-maximize",
    "core:webview:allow-internal-toggle-devtools",
    "opener:default",
    "dialog:default",
    "fs:default",
    "shell:default",
    "autostart:default"
  ]
}
